# Server
NODE_ENV=development
PORT=3000

# Database
# Local SQLite (default for dev):
DATABASE_URL=file:emcomm.db
# Turso remote database (required in production):
# DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Authentication
# REQUIRED in production — must not equal the dev default when NODE_ENV=production
JWT_SECRET=emcomm-dev-secret-change-in-production

# CORS (comma-separated origins; defaults to localhost:5173 in dev)
# CORS_ALLOWED_ORIGINS=https://your-app.fly.dev,https://your-custom-domain.com

# Email (for invite flow — set in a later milestone)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_resend_api_key
